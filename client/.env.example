## ConfigPilot - Vite environment variables
#
# Local development:
# VITE_API_URL=http://localhost:5000/api
#
# Production (example):
# VITE_API_URL=https://configpilot-api.onrender.com/api
#
# NOTE:
# - Only variables prefixed with VITE_ are exposed to the browser.
# - Do not put secrets here.

VITE_API_URL=http://localhost:5000/api

